{
  "name": "fishplus-distributor",
  "productName": "FISHPLUS Distributor",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": "src/main/index.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:renderer": "vite --config src/renderer/vite.config.js",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build --config src/renderer/vite.config.js",
    "build:electron": "electron-builder",
    "build": "npm run build:renderer && npm run build:electron",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\"",
    "rebuild": "npx electron-rebuild"
  },
  "keywords": [],
  "author": {
    "name": "Haris Khan",
    "email": "hariskhan936.hk@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "40.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@jsreport/jsreport-chrome-pdf": "^4.4.0",
    "@jsreport/jsreport-handlebars": "^4.1.0",
    "@mantine/core": "^8.3.14",
    "@mantine/dates": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/modals": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@tabler/icons-react": "^3.36.1",
    "better-sqlite3": "^12.6.2",
    "dayjs": "^1.11.19",
    "exceljs": "^4.4.0",
    "i18next": "^25.8.11",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "jsreport-core": "^2.10.1",
    "pdfmake": "^0.3.4",
    "prop-types": "^15.8.1",
    "puppeteer-core": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "zustand": "^5.0.11"
  }
}